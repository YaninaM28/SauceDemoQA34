<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="SauceDemo suite"
       parallel="tests">

    <listeners>
        <listener class-name="tests.TestListener"/>
    </listeners>

    <test name="Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.CheckoutOverviewTest"/>
            <class name="tests.CheckoutInfoTest"/>
            <class name="tests.RemoveFromCartTest"/>
            <class name="tests.EndToEndTest"/>
            <class name="tests.LogoutTest"/>
        </classes>
    </test>

    <test name="Edge">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.CartTest"/>
            <class name="tests.CheckoutOverviewTest"/>
            <class name="tests.CheckoutInfoTest"/>
            <class name="tests.RemoveFromCartTest"/>
            <class name="tests.EndToEndTest"/>
            <class name="tests.LogoutTest"/>
        </classes>
    </test>
</suite>
